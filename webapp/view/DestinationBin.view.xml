            <HBox class="sapUiTinyMargin sapUiSmallMarginBegin">
                <Button text="Clear" icon="sap-icon://reset" type="Emphasized" class="sapUiTinyMarginEnd" press=".onClear"/>
                <Button text="Back" icon="sap-icon://media-reverse" class="sapUiTinyMarginEnd" press=".onBack"/>
                <Button text="Next" icon="sap-icon://media-play" press=".onNext"/>
            </HBox>
            <l:Grid defaultSpan="XL6 L6 M6 S12">
                <!-- Destination Information -->
                <form:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="2" labelSpanL="2" labelSpanM="4" labelSpanS="12" emptySpanXL="6" emptySpanL="6" emptySpanM="1" emptySpanS="0" class="sapUiTinyMarginBottom customVBoxBorder">

                    <Title text="Destination info." level="H4"/>

                    <Label text="Dest. Str. Bin"/>
                    <HBox>
                        <Input editable="false" value="{scannerModel>destinationStorageType}" width="4rem"/>
                        <Input id="inputDestinationBin" submit=".onNext" placeholder="Scan Destination Bin"  valueLiveUpdate="true" value="{scannerModel>destinationBin}" class="sapUiTinyMarginBegin" width="100%"/>
                    </HBox>

                    <Label text="Plant"/>
                    <Input value="INA1" editable="false"/>

                    <Label text="Count"/>
                    <HBox>
                        <Input editable="false" value="{= ${scannerModel>/currentIndex} + 1 }" width="4rem"/>
                        <Text text="/" class="sapUiTinyMargin sapUiTinyPaddingBottom"/>
                        <Input editable="false" value="{scannerModel>/totalCount}" width="4rem"/>
                    </HBox>

                </form:SimpleForm>
            </l:Grid >

            <l:Grid defaultSpan="XL6 L6 M6 S12">
                <!-- Material Information -->
                <form:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="2" labelSpanL="2" labelSpanM="4" labelSpanS="12" emptySpanXL="6" emptySpanL="6" emptySpanM="1" emptySpanS="0" columnsXL="3" columnsL="2" columnsM="1" class="customVBoxBorder">

                    <Title text="Material information" level="H4"/>

                    <Label text="Material"/>
                    <Input value="{scannerModel>batch}" editable="false"/>

                    <Label text="Batch"/>
                    <Input value="{scannerModel>inputBatch}" editable="false"/>

                    <Label text="Mat. Description"/>
                    <Input value="POWERNET" editable="false"/>

                    <Label text="Grid"/>
                    <Input value="00041920" editable="false"/>

                    <Label text="Ven. Dye Lot"/>
                    <Input editable="false"/>

                    <Label text="Quantity"/>
                    <HBox>
                        <Input value="79.000" width="8rem"/>
                        <Input value="M" width="2rem" editable="false" class="sapUiTinyMarginBegin"/>
                    </HBox>

                </form:SimpleForm>
            </l:Grid>

        </content>
    </Page>
</mvc:View>